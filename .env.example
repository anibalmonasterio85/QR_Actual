# QR Access PRO - Environment Configuration Example
# Copy this to .env and fill in your values

# ========== DATABASE ==========
DB_HOST=localhost
DB_PORT=3306
DB_USER=qr_access
DB_PASSWORD=your_secure_password_here
DB_NAME=qr_access_db

# ========== CACHE (REDIS) ==========
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=  # Leave empty if no password

# ========== FLASK ==========
FLASK_APP=web_panel/app.py
FLASK_ENV=production  # development or production
FLASK_DEBUG=0
SECRET_KEY=change-me-to-a-random-secure-key-at-least-32-chars

# ========== SECURITY ==========
SESSION_TIMEOUT=28800  # 8 hours in seconds
PERMANENT_SESSION_LIFETIME=28800
SESSION_COOKIE_SECURE=true  # Set to true in HTTPS
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax

# ========== EMAIL CONFIGURATION ==========
# Gmail Example
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password  # NOT your regular password
MAIL_DEFAULT_SENDER=noreply@qraccess.pro

# Alternative: Office 365
# MAIL_SERVER=smtp.office365.com
# MAIL_PORT=587
# MAIL_USERNAME=your-email@company.com
# MAIL_PASSWORD=your-password

# ========== QR CONFIGURATION ==========
QR_ERROR_CORRECTION=HIGH  # L, M, Q, HIGH
QR_BOX_SIZE=10
QR_BORDER=4
QR_VERSION=1  # Auto version detection
TOTP_WINDOW=1  # ±30 second tolerance

# ========== LOGGING ==========
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=structured  # structured or plain
LOG_RETENTION_DAYS=30

# ========== RATE LIMITING ==========
RATE_LIMIT_ENABLED=true
LOGIN_RATE_LIMIT=10/minute  # 10 tries per minute
API_RATE_LIMIT=30/minute
GENERAL_RATE_LIMIT=100/minute

# ========== GEOLOCATION ==========
GEOIP_ENABLED=false  # Requires MaxMind GeoIP2 database
GEOIP_DB_PATH=data/GeoLite2-City.mmdb

# ========== NOTIFICATIONS ==========
NOTIFY_ON_FAILED_ACCESS=true
NOTIFY_ON_NEW_ADMIN=true
NOTIFY_THRESHOLD_FAILED=5  # Alert after N failed attempts

# ========== EXTERNAL SERVICES ==========
# Slack (optional)
SLACK_WEBHOOK_URL=  # https://hooks.slack.com/services/...

# Sentry (optional - error tracking)
SENTRY_DSN=  # https://...@sentry.io/...

# ========== FEATURES ==========
ENABLE_BIOMETRIC=false  # Face recognition security
ENABLE_API_DOCS=true  # Swagger UI at /api/docs
ENABLE_MULTI_TENANT=false  # SaaS mode

# ========== DEPLOYMENT ==========
ENVIRONMENT=production  # production, staging, development
API_BASE_URL=https://api.qraccess.pro
WEB_URL=https://qraccess.pro
ALLOWED_ORIGINS=https://qraccess.pro,https://admin.qraccess.pro

# ========== BACKUP & MAINTENANCE ==========
BACKUP_ENABLED=true
BACKUP_TIME=03:00  # UTC time for daily backup
BACKUP_RETENTION_DAYS=30

# ========== ADVANCED ==========
# Workers (Gunicorn)
WORKERS=4
WORKER_CLASS=sync  # sync, gevent, etc
MAX_REQUESTS=1000
TIMEOUT=60

# Database Pool
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600

# Cache
CACHE_TTL_SHORT=300  # 5 minutes
CACHE_TTL_MEDIUM=1800  # 30 minutes
CACHE_TTL_LONG=3600  # 1 hour

# ========== DEBUG (DEVELOPMENT ONLY) ==========
DEBUG=0
DEBUG_TB_ENABLED=0
DEBUG_TB_INTERCEPT_REDIRECTS=0
EXPLAIN_TEMPLATE_LOADING=0
